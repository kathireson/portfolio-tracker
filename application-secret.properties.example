# -----------------------------------------------
# SECRETS TEMPLATE
# -----------------------------------------------
# Copy this file to application-secret.properties and fill in your values.
# The .properties file is gitignored; this .example file is safe to commit.

# Keycloak OAuth2
# Your Keycloak realm issuer URI (includes internal/homelab IP or hostname)
KEYCLOAK_ISSUER_URI=https://<KEYCLOAK_HOST>:8180/realms/<YOUR_REALM>
KEYCLOAK_CLIENT_SECRET=<your-client-secret>
OAUTH_REDIRECT_URI=http://localhost:8080

# Alpha Vantage (only needed if portfolio.quote-provider=ALPHA_VANTAGE)
ALPHA_VANTAGE_API_KEY=<your-api-key>
